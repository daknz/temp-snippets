Function StripNonAlphanumeric(inputString As String) As String
  
  Dim regex As Object
  Set regex = CreateObject("VBScript.RegExp")
  
  With regex
    .Pattern = "[^a-zA-Z0-9]" ' Match anything that is not a letter or a digit
    .Global = True ' Ensures all matches in the string are replaced, not just the first one.

  End With
  
  ' Replace all non-alphanumeric characters with an empty string
  StripNonAlphanumeric = regex.Replace(inputString, "")

End Function

