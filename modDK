Sub goToNextVisibleCellDownInColumn()

'''Moves down to the next cell that isn't hidden
'''Can set blanksOnly to 0 or 1 (i.e. go to any visible cell, or only blank ones)

'''Based on https://stackoverflow.com/questions/17890004/using-an-or-function-within-range-find-vba
'''Only works if table starts in A1
'''Uses Find to get the next blank or non blank cell (I originally had as below, but Find it doesn't actually search non visible anyway)
    'Set rngNextBlank = ActiveCell.ListObject.DataBodyRange.Columns(ActiveCell.Column).SpecialCells(xlCellTypeVisible).Find(What:="", _

Dim rngNextBlank As Range
Dim rngNextNonBlank As Range
Dim blanksOnly

blanksOnly = 1  'Set to 1 to only jump to blank cells

'''Find the next blank visible cell in the current table column (doesn't have ".Activate" at the end to actually jump to it, just gets the range where it would be)
Set rngNextBlank = ActiveCell.ListObject.DataBodyRange.Columns(ActiveCell.Column).Find(What:="", _
    after:=ActiveCell, LookIn:=xlValues, LookAt:=xlPart, SearchOrder:=xlByColumns, _
    SearchDirection:=xlNext, MatchCase:=False, SearchFormat:=False)

'''Find the next non blank cell
Set rngNextNonBlank = ActiveCell.ListObject.DataBodyRange.Columns(ActiveCell.Column).Find(What:="*", _
    after:=ActiveCell, LookIn:=xlValues, LookAt:=xlPart, SearchOrder:=xlByColumns, _
    SearchDirection:=xlDown, MatchCase:=False, SearchFormat:=False)

'Debug.Print ActiveCell.Row & ", " & rngNextBlank.Row & ", " & rngNextNonBlank.Row

If blanksOnly = 1 Then
    '''Only check if there are any non blank cells found and then jump to the next one down
    If Not rngNextBlank Is Nothing Then
        If rngNextBlank.row > ActiveCell.row Then
            Cells(rngNextBlank.row, ActiveCell.Column).Select
        End If
    End If
ElseIf Not rngNextBlank Is Nothing And Not rngNextNonBlank Is Nothing Then
    '''It's found both blank and non blank
    If rngNextBlank.row > ActiveCell.row And rngNextNonBlank.row > ActiveCell.row Then
        Debug.Print "A1: both cells found are below the active cell"
        Cells(Application.Min(rngNextBlank.row, rngNextNonBlank.row), ActiveCell.Column).Select
    ElseIf rngNextBlank.row > ActiveCell.row Then
        Debug.Print "A2: only the blank cell is below the active cell (the non blank is above, so ignore it)"
        Cells(rngNextBlank.row, ActiveCell.Column).Select
    ElseIf rngNextNonBlank.row > ActiveCell.row Then
        Debug.Print "A3: only the non blank cell is below the active cell (the blank cell is above, so ignore it)"
        Cells(rngNextNonBlank.row, ActiveCell.Column).Select
    Else
        Debug.Print "A4: at the bottom, won't do anything"
    End If
ElseIf rngNextBlank Is Nothing Then
    '''i.e. no blank cells visible in the active column
    If rngNextNonBlank Is Nothing Then
        Debug.Print "B: neither found (shouldn't ever happen?)"
    Else
        Debug.Print "C: only non blank cells, will jump to the next unless at the bottom"
        If rngNextNonBlank.row > ActiveCell.row Then
            Cells(rngNextNonBlank.row, ActiveCell.Column).Select
        End If
    End If
Else
    '''i.e. no non blank cells visible in the active column
    'Debug.Print "D: only looking for blank cells, and there are none"

    If rngNextBlank.row > ActiveCell.row Then
        Debug.Print "E: only blank cells, will jump to the next unless at the bottom"
        Cells(rngNextBlank.row, ActiveCell.Column).Select
    End If
End If

End Sub

