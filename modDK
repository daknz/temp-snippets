  '# Called from Word_ImportCommentsToWorkbook.
    '# includeOnlyUnresolved is set there in code (True to skip resolved comments).  If False, then the end below will filter to resolved comments and select all ready to delete

  TbCreate
  'TbSetup
  
  TbCol("Date").Range.HorizontalAlignment = xlLeft
  TbCol("Reply Count").Range.HorizontalAlignment = xlLeft
  
  Call LcCreate("Reply Count2", , "=IF([@Type]=""Comment"",[@[Reply Count]],R[-1]C)", True)
  Call LcCreate("Original Person", , "=IF([@Type]=""Comment"",[@Person],R[-1]C)", True)
  Call LcCreate("Action Required", , "=IF([@Type]=""Comment"",IF([@[Reply Count]]=0,""zAUTHOR"",[@[Original Person]]),R[-1]C)", True)

  TbCol("Person").Range.ColumnWidth = 20
  TbCol("Comment").Range.ColumnWidth = 100
  TbCol("Comment").DataBodyRange.WrapText = True
  Cells.EntireRow.autoFit
  tb.ShowTableStyleRowStripes = False
  
  Call Word_CommentsSortAndFormat
  
  If includeOnlyUnresolved = False Then
  
    '# Filter to TRUE, ready to delete resolved comments (VBA gives an error deleting non-continuous filtered rows)
    tb.Range.AutoFilter field:=TbCol("Resolved").Range.Column, Criteria1:="TRUE"
      
    If Application.WorksheetFunction.Subtotal(103, tb.ListColumns(1).DataBodyRange) > 0 Then
      '# Won't work
      'tb.DataBodyRange.SpecialCells(xlCellTypeVisible).EntireRow.Delete
      'TbFilterClear
          
      '# Alternate option ready to delete manually (only seems to work if select table rows, not entire row)
      tb.DataBodyRange.SpecialCells(xlCellTypeVisible).Select
    End If
    
  End If
  
End Sub

Sub Word_CommentsFormatExport2()

  Dim c As Range
  Dim lr As ListRow
  Dim newRow As ListRow
  
  TbSetup
  
  '# Sort first time as may have manually marked some as 'AUTHOR'
  Word_CommentsSortAndFormat
  
  '# Create a new temporary column to see if Action Required is the same in the previous row
  LcCreate "TEMP", , "=[@[Action Required]]=R[-1]C[-1]", True

  Dim i As Long
  For i = tb.ListRows.count To 1 Step -1  '# I.e. loop backwards through listrows
    Set lr = tb.ListRows(i)
    Set c = TbCellRng(lr, "TEMP")
    
    '# If Action Required wasn't the same in the previous row, insert a new header row (effectively section header) for that person
    If c.value = False Then
      lr.Range.EntireRow.Insert
      Set newRow = tb.ListRows(i)           '# newly inserted row
      Set lr = tb.ListRows(i + 1)           '# shifted-down row with source data

      '# Copy "Action Required" value from old row to new row fields
      Dim val As String
      val = TbCellRng(lr, "Action Required").value

      TbCellRng(newRow, "Comment").value = val
      TbCellRng(newRow, "Original Person").value = Replace(val, "zAUTHOR", "aaaa")
      TbCellRng(newRow, "Action Required").value = val
    End If
  Next

  '# Sort again
  Word_CommentsSortAndFormat

End Sub


Sub Word_CommentsSortAndFormat()

  Dim lr As ListRow
  
  TbSort "Action Required", , "Original Person"
  
  For Each lr In tb.ListRows
    Debug.Print "TEMP Word_CommentsSortAndFormat lr.Index: " & lr.Index
    
    Select Case TbCellVal(lr, "Type")
    
      Case "Comment"
        LrSetBorder lr, xlEdgeTop, , rgbGray
      
      Case "Reply"
        LrSetBorder lr, , , , True
        lr.Range.Font.Color = RGB(111, 111, 111)
            
      Case ""
        LrSetBorder lr, xlEdgeTop, xlMedium
      
        With lr.Range.Font
          .Size = 12
          .Bold = True
        End With
        
        '# Caters for row being inserted under the header which means it needs to have the shading removed
        With lr.Range.Interior
          .Pattern = xlNone
          .TintAndShade = 0
          .PatternTintAndShade = 0
        End With
        
      Case Else
          
    End Select
    
  Next

End Sub


Sub sbGetQueryContentOLD()

'# Can't use because SpecialCells doesn't stick with columns then rows if hidden column

'# Turn a table into (part of) SQL query based on visible columns and rows

Dim cRow, rowVals, outputVals, headerRow As Boolean

TbSetup

For Each c In tb.Range.SpecialCells(xlCellTypeVisible)
  'Debug.Print c.Address

  If cRow <> c.row Then '# new row

    If cRow = "" Then
      headerRow = True
    Else
      headerRow = False
      '# Add a line, remove the last 2 chars ... i.e. the final ", " ... and add ")," at the end
      outputVals = outputVals + vbLf + Left(rowVals, Len(rowVals) - 2) & "),"
    End If

    '# Start new line
    rowVals = ""
    rowVals = "(" & sbCellOutput(c, headerRow) & ", "
    cRow = c.row

  Else  '# same row

    rowVals = rowVals & sbCellOutput(c, headerRow) & ", "

  End If


Next
Exit Sub
'# Final row
outputVals = outputVals + vbLf + Left(rowVals, Len(rowVals) - 2) & "),"


'# Copy to clipboard (needs Tools > References: Forms 2.0 Object Library ticked)
With New DataObject
    .SetText outputVals
    .PutInClipboard
