      Set lcColumnName = newTable.ListColumns.Add
      lcColumnName.Name = columnName
      newDict.Add lcColumnName.Name, lcColumnName
    End If
          
    '# Add formula to look up the same ID and column name to find the previous value in the old table (or otherwise blank)
    lcColumnName.DataBodyRange.Formula2R1C1 = _
      "=LET(PrevVal,XLOOKUP([@ID]," & oldTable.Name & "[ID]," & oldTable.Name & "[" & columnName & "],"""")," & Chr(10) & "IF(PrevVal="""","""",PrevVal)" & Chr(10) & ")"
    
    '# Replace formulas with values
    lcColumnName.DataBodyRange.value = lcColumnName.DataBodyRange.value
    lcColumnName.Range(1).Interior.Color = RGB(21, 96, 130)
    lcColumnName.Range.EntireColumn.autoFit
    
  Next columnName


  
  ' Step 3: Add "Added" and "Removed" formulas
  Dim lcChangeStatusNew As ListColumn, lcChangeStatusOld As ListColumn
  
  ' Add "ChangeStatus" column to the new table
  Set lcChangeStatusNew = newTable.ListColumns.Add
  lcChangeStatusNew.Name = "ChangeStatus"
  '# Add a formula that checks if the ID existed in the old table (will show "Added" if not), or if the comparisonColumn from modConfig has changed (will show old and new vals)
  lcChangeStatusNew.DataBodyRange.Formula2R1C1 = _
    "=LET(oldVal,XLOOKUP([@ID]," & oldTable.Name & "[ID]," & oldTable.Name & "[" & comparisonColumn & "],""NotFound"")," & Chr(10) & "  IF([@[" & comparisonColumn & "]]=oldVal,""""," & Chr(10) & "  IF(oldVal=""NotFound"",""Added""," & Chr(10) & "  ""Release: "" & oldVal & "" > "" & [@[" & comparisonColumn & "]]))" & Chr(10) & ")"
      
        '# NB: ends up like this (where "Key Col" is the name of a column where I'm checking if the value has changed:
          '=LET(oldVal,XLOOKUP([@ID],tblOld3[ID],tblOld3[Key Col],"NotFound"),
          '  IF([@[Key Col]]=oldVal,"",
          '  IF(oldVal="NotFound","Added",
          '  "Release: " & oldVal & " > " & [@[Key Col]]))
          ')
        
    
'    "=IF(ISERROR(MATCH([@" & lcID.Name & "]," & oldTable.Name & "[ID],0)),""Added"","""")"
  lcChangeStatusNew.DataBodyRange.value = lcChangeStatusNew.DataBodyRange.value
  lcChangeStatusNew.Range(1).Interior.Color = RGB(21, 96, 130)
  
  If includeChangeLog = True Then
    ' Add "Added" rows from newTable to change log
    Call UpdateChangeLog(newTable)
  End If

  ' Add "ChangeStatus" column to the old table
  On Error Resume Next
  Set lcChangeStatusOld = oldTable.ListColumns("ChangeStatus")   ' ** won't work if using Tools > Options > Break on All Errors
  On Error GoTo 0
  If lcChangeStatusOld Is Nothing Then
    Set lcChangeStatusOld = oldTable.ListColumns.Add
    lcChangeStatusOld.Name = "ChangeStatus"
  End If
  lcChangeStatusOld.DataBodyRange.Formula2R1C1 = _
    "=IF(ISERROR(MATCH([@ID]," & newTable.Name & "[" & lcID.Name & "],0)),""Removed"","""")"
  lcChangeStatusOld.DataBodyRange.value = lcChangeStatusOld.DataBodyRange.value
  lcChangeStatusOld.Range(1).Interior.Color = RGB(21, 96, 130)
  
  If includeChangeLog = True Then
    ' Add "Removed" rows from oldTable to change log
    Call UpdateChangeLog(oldTable)
  End If
  
  ' Clean up
  Set oldDict = Nothing
  Set newDict = Nothing
  
End Sub

Sub UpdateChangeLog(srcTable As ListObject)
  '# Called from SyncTableData.  Assumes have a table in a Change Log tab with at least one row, and first three columns are ID, ID2, Change Type (ID is a formula to get the link based on ID2)
  
  Dim wsSource As Worksheet, tblChangeLog As ListObject
  Dim filteredArray As Variant
  Dim startCell As Range
  Dim changeStatusCol As Long, idCol As Long, modifiedCount As Long

  ' Set the change log table
  Set tblChangeLog = ActiveWorkbook.Worksheets("Change Log").ListObjects(1)

  ' Get the column indexes (i.e. relative to the table, in case it doesn't start in column A) for "ID" and "ChangeStatus"
  idCol = srcTable.ListColumns("ID").Index
  changeStatusCol = srcTable.ListColumns("ChangeStatus").Index
  ' Use COUNTIF to determine the number of rows with a value in the ChangeStatus column. I.e. =COUNTIF(tblBlah[ChangeStatus],"*?") ... a way of counting non-blanks when the column has a formula ("<>" doesn't work in this case)
  modifiedCount = srcTable.Parent.Evaluate("COUNTIF(" & srcTable.ListColumns(changeStatusCol).DataBodyRange.Address & ",""*?"")")

  ' Exit if no rows match
  If modifiedCount = 0 Then
      'Debug.Print "No rows with 'Added/Removed' found."
    Exit Sub
  End If

'  '# Use FILTER only to get all columns in the table
'  filteredArray = srcTable.Parent.Evaluate("FILTER(" & srcTable.DataBodyRange.Address & ", " & srcTable.ListColumns(changeStatusCol).DataBodyRange.Address & "=""Added"")")
  ' Use FILTER and CHOOSE to select the desired columns and filter rows where it's not blank
  filteredArray = srcTable.Parent.Evaluate("FILTER(CHOOSE({1,2}," & srcTable.ListColumns(idCol).DataBodyRange.Address & "," & srcTable.ListColumns(changeStatusCol).DataBodyRange.Address & "), " & srcTable.ListColumns(changeStatusCol).DataBodyRange.Address & "<>"""")")

  ' Set the first cell where the array values will go - the row below the last row of the destination table, and the second column (ID2)
  Set startCell = tblChangeLog.DataBodyRange.Cells(tblChangeLog.ListRows.count + 1, 2)

  ' Process based on the number of rows
  If modifiedCount = 1 Then
    ' Write the single row (1D array)
    startCell.Resize(1, UBound(filteredArray)).value = filteredArray
  Else
    ' Write multiple rows (2D array)
    startCell.Resize(UBound(filteredArray, 1), UBound(filteredArray, 2)).value = filteredArray
  End If

End Sub



