Function TbCol(colName As String) As ListColumn

  '# Returns the ListColumn object from the current table (tb)
  
  Dim matchResult As Variant
  
  matchResult = Application.Match(colName, tb.HeaderRowRange, 0)

  If IsNumeric(matchResult) Then
    Set TbCol = tb.ListColumns(CLng(matchResult))
  Else
    Set TbCol = Nothing
  End If

End Function

Function TbCellRng(rowOrIndex As Variant, colName As String) As Range
  '# Returns a Range for the named column. rowOrIndex can be 0 (for the header), a row number, or a ListRow object

  Dim targetCol As ListColumn
  
  Set targetCol = tb.ListColumns(colName)
  
  If IsObject(rowOrIndex) Then
    '# ListRow passed
    Set TbCellRng = rowOrIndex.Range(targetCol.Index)

  ElseIf IsNumeric(rowOrIndex) Then
    Dim i As Long
    i = CLng(rowOrIndex)

    If i = 0 Then
      '# Header cell
      Set TbCellRng = targetCol.Range.Cells(1)
    Else
  
      If i < 1 Or i > tb.ListRows.count Then
        Err.Raise vbObjectError + 514, , "TbCellRng error: row index (" & i & ") cannot exceed table row count (" & tb.ListRows.count & ")."
      End If
  
      Set TbCellRng = tb.ListRows(i).Range(targetCol.Index)
    End If
  Else
    Err.Raise vbObjectError + 513, , "TbCellRng error: invalid rowOrIndex input."
  End If
  
  '# EXAMPLE USAGE -------------------------
  
'  Set c = TbCellRng(0, "Comment")               '# Header
'  Set c = TbCellRng(3, "Comment")               '# Row index 3
'  Set c = TbCellRng(tb.ListRows(3), "Comment")  '# Row object

End Function

