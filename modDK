Sub Word_ImportCommentsToWorkbook()

  Const includeOnlyUnresolved As Boolean = True  '# True to skip resolved comments

  Dim wdDoc As Object
  Set wdDoc = Word_SelectOpenDocument()
  If wdDoc Is Nothing Then Exit Sub

  Dim xlWS As Worksheet
  Set xlWS = ActiveSheet

  '# Stop all procedures if no comments
  If wdDoc.Comments.count = 0 Then
    Debug.Print "Word_ImportCommentsToWorkbook: no comments in "; wdDoc.Name
    End
  End If

  '# Write headers
  With xlWS
    .Range("A1:G1").value = Array("Person", "Comment", "Section", "Date", "Resolved", "Reply Count", "Type")
    .Rows(1).Font.Bold = True
  End With

  Dim i As Long, r As Long
  Dim c As Object  '# Word.Comment
  Dim rowIndex As Long: rowIndex = 0
  Dim dataArray() As Variant
  ReDim dataArray(1 To 7, 1 To 1)  '# [col, row] — we’ll preserve and expand as needed. See further notes at the end

  '# Loop through all comments in the Word doc
  For i = 1 To wdDoc.Comments.count
    Set c = wdDoc.Comments(i)

    '# Skip replies - we will get them from .Replies instead
    If Not c.Ancestor Is Nothing Then GoTo NextComment

    '# Skip resolved comments if the flag is set
    If includeOnlyUnresolved And c.Done Then GoTo NextComment

    '# Add comment row
    rowIndex = rowIndex + 1
    ReDim Preserve dataArray(1 To 7, 1 To rowIndex)
    dataArray(1, rowIndex) = c.Author
    dataArray(2, rowIndex) = c.Range.Text
    dataArray(3, rowIndex) = Word_GetNearestHeading(c.Scope)  '# Related Heading
    dataArray(4, rowIndex) = c.Date
    dataArray(5, rowIndex) = c.Done  '# Replies also have .Done
    dataArray(6, rowIndex) = c.Replies.count
    dataArray(7, rowIndex) = "Comment"

    '# Add replies as additional rows
    For r = 1 To c.Replies.count
      rowIndex = rowIndex + 1
      ReDim Preserve dataArray(1 To 7, 1 To rowIndex)
      dataArray(1, rowIndex) = c.Replies(r).Author
      dataArray(2, rowIndex) = ">> " & c.Replies(r).Range.Text  '# Prefix with ">>"
'      dataArray(3, rowIndex) = Word_GetNearestHeading(c.Replies(r).Scope)  '# Related Heading (always the same, so unnecessary)
      dataArray(3, rowIndex) = " "
      dataArray(4, rowIndex) = c.Replies(r).Date
      dataArray(5, rowIndex) = c.Replies(r).Done  '# Likely same as parent
      dataArray(6, rowIndex) = c.Replies(r).Replies.count  '# Likely always 0
      dataArray(7, rowIndex) = "Reply"
    Next r

NextComment:
  Next i

  '# Transpose to write in one go (Excel expects row then column)
  If rowIndex > 0 Then
    Dim finalArray() As Variant
    ReDim finalArray(1 To rowIndex, 1 To 7)
    Dim col As Long, row As Long
    For col = 1 To 7
      For row = 1 To rowIndex
        finalArray(row, col) = dataArray(col, row)
      Next row
    Next col

    xlWS.Range("A2").Resize(rowIndex, 7).value = finalArray
  End If

  xlWS.Columns.autoFit

  Call Word_CommentsFormatExport(includeOnlyUnresolved)

  '#NB: typically Excel does arrays as rows/columns. We had issues with how Excel VBA treats ReDim Preserve on both dimensions of a 2D array
    '# so instead this uses a "column then row" array first (dataArray), then transposes to finalArray (row then column) before writing the output

End Sub

Function Word_SelectOpenDocument() As Object
  '# Returns a Word.Document object selected by the user from open Word documents

  Dim wdApp As Object
  On Error Resume Next
  Set wdApp = GetObject(, "Word.Application")
  On Error GoTo 0

  If wdApp Is Nothing Then
    MsgBox "Word is not open.", vbExclamation
    Exit Function
  End If

  If wdApp.Documents.count = 0 Then
    MsgBox "No Word documents are open.", vbExclamation
    Exit Function
  End If

  Dim docList As String
  Dim i As Long
  For i = 1 To wdApp.Documents.count
    docList = docList & i & ": " & wdApp.Documents(i).Name & vbCrLf
  Next i

  Dim docIndex As Variant
  docIndex = InputBox("Choose a Word document by number:" & vbCrLf & vbCrLf & docList, "Select Word Doc")

  If Not IsNumeric(docIndex) Then Exit Function
  Dim docNum As Long: docNum = CLng(docIndex)

  If docNum < 1 Or docNum > wdApp.Documents.count Then Exit Function

  Set Word_SelectOpenDocument = wdApp.Documents(docNum)
End Function


Function Word_GetNearestHeading(rng As Object) As String
  '# Used in Word_ImportCommentsToWorkbook to get the nearest parent heading (including numbering if applicable)
  Dim para As Object
  Dim headingText As String

  On Error Resume Next
  Set para = rng.Paragraphs(1)

  Do While Not para Is Nothing
    If para.Style Like "Heading *" Then
      headingText = para.Range.ListFormat.ListString & " " & para.Range.Text
      headingText = Trim(Replace(headingText, vbCr, ""))  '# Clean trailing line breaks
      Exit Do
    End If
    Set para = para.Previous
  Loop

  If headingText = "" Then
    Word_GetNearestHeading = "-"
  Else
    Word_GetNearestHeading = headingText
  End If
End Function



