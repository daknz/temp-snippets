Function GetWorkbooks(Optional selectionType As String) As Variant
  '# Returns an array of workbook objects matching the selectionType criteria (if not provided - returns all workbooks, including hidden)
  '# (NB: VBA functions cannot directly return arrays of object types, like Workbook, unless the return type is Variant)

  '# selectionType options (for now not using enum since it needs to be declared at module level):
    ' "visible", "withTable" (other workbooks that have a table in them)

  Dim item As Workbook
  Dim interimArray() As Workbook
  Dim i As Long
  Dim includeItem As Boolean

  ' Initialize a dynamic array
  ReDim interimArray(0)
  i = -1  ' Start at -1 to handle resizing correctly
 
 
  For Each item In Workbooks
    includeItem = False
    
    Select Case selectionType
      
      Case "visible"    '# Only include visible workbooks
        If Windows(item.Name).Visible = True Then includeItem = True
      
      Case Else         '# Default is to include visible workbooks only
        If Windows(item.Name).Visible = True Then includeItem = True

    End Select

    ' Add item if it meets the criteria
    If includeItem Then
      i = i + 1
      ReDim Preserve interimArray(i)
      Set interimArray(i) = item
    End If
    
    'Debug.Print "GetItems: "; item.Name; " "; includeItem

  Next item
  
  'Debug.Print "-------"
    
  ' Handle case where no items matched criteria
  If i = -1 Then
    GetWorkbooks = Array()  ' Return an empty array
  Else
    '# Assigns the dynamic array interimArray (which contains Workbook object references) to the function's return value, making it the output of the GetWorkbooks function.
    GetWorkbooks = interimArray
  End If
  
  '## Other notes
  '# Since the return type of GetWorkbooks is declared as Variant, the array is automatically wrapped in a Variant to allow it to be passed or returned (functions cannot directly return arrays of objects unless the return type is Variant).
  
End Function

Function GetSheets(Optional selectionType As String, Optional parentWorkbook As Workbook) As Variant
  '# Returns an array of worksheet objects matching the selectionType criteria (if not provided - returns all sheets, including hidden)
  '# (NB: VBA functions cannot directly return arrays of object types, like Worksheet, unless the return type is Variant)
  '# Can optionally pass in a 'parent' workbook if not referring to sheets in the active workbook

  '# selectionType options (for now not using enum since it needs to be declared at module level):
    ' "visible", "withTable" (other sheets that have a table in them)

  Dim result As New Collection
  Dim item As Worksheet
  Dim interimArray() As Worksheet
  Dim i As Long
  Dim includeItem As Boolean

  If parentWorkbook Is Nothing Then
    Set parentWorkbook = ActiveWorkbook
  End If

  ' Initialize a dynamic array
  ReDim interimArray(0)
  i = -1  ' Start at -1 to handle resizing correctly
 
 
  For Each item In parentWorkbook.Sheets
    includeItem = False
    
    Select Case selectionType
      
      Case "visible"    '# Only include visible sheets
        If item.Visible = xlSheetVisible Then includeItem = True
      
      Case "withTable"  '# Only include sheets other than the current sheet, and with a single table in them
'        If item.Name <> ActiveSheet.Name And item.ListObjects.count = 1 Then includeItem = True
        'If item <> ActiveSheet And item.ListObjects.count = 1 Then includeItem = True
        If item.ListObjects.count = 1 Then includeItem = True
      
      Case Else         '# Default is to include all sheets, including hidden
        includeItem = True
    
    End Select

    ' Add item if it meets the criteria
    If includeItem Then
      i = i + 1
      ReDim Preserve interimArray(i)
      Set interimArray(i) = item
    End If
    
    'Debug.Print "GetItems: "; item.Name; " "; includeItem

  Next item
  
'  Debug.Print "IsArrayPopulated(Me.itemsArray): "; IsArrayPopulated(Me.itemsArray)
  
  If i = -1 Then
    '# I.e. no items matched criteria
      'Debug.Print "GetSheets: i = -1"
      result.Add Array(), "SheetsArray"  ' Add an empty array to the collection
  
  Else
'    '# Assigns the dynamic array interimArray (which contains Worksheet object references) to the collection in the function's return value, making it the output of the GetSheets function.
      result.Add interimArray, "SheetsArray"  ' Add the populated array to the collection
  
  End If
  
  result.Add parentWorkbook, "ParentWorkbook"  ' Add the parent workbook to the collection
  
  Set GetSheets = result
  
'  '## Other notes
'  '# Since the return type of GetSheets is declared as Variant, the array is automatically wrapped in a Variant to allow it to be passed or returned (functions cannot directly return arrays of objects unless the return type is Variant).

End Function

