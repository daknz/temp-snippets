Sub SyncTableData(oldSheet As Worksheet, addIdLinksColumn As Boolean, formulaColumns As Variant, _
      textColumns As Variant, comparisonColumn As String, createChangeLog As Boolean)
  '# Call from SyncTableDataConfig (which will set columns that need to be in the other sheet)
  '# formulaColumns: array of strings with column names that have formulas. textColumns: same for columns with plain text.
  
  '* ToDo: more explanation. E.g. adds new columns , how ID works, ...
  '* ToDo: feels like newDict can be rationalised into a single one?
  
  Dim oldTable As ListObject, newTable As ListObject
  Dim oldDict As Object, newDict As Object
  Dim rowIndex As Long
  Dim arrData() As Variant
  Dim key As String
  Dim columnName As Variant, lcColumnName As ListColumn
  Dim lcID As ListColumn, lcText As ListColumn
  Dim tblChgLog As ListObject, lrLogEntry As ListRow
  
  
  '# Initialize dictionary (key/value pairs - in this case the value will be an array [*CHECK: still the case?])
  Set oldDict = CreateObject("Scripting.Dictionary")
  
  '# Reference the old and new tables
  Set oldTable = oldSheet.ListObjects(1)
  Set newTable = ActiveSheet.ListObjects(1)
  
  ' Create a dictionary to store existing column names
  Set newDict = CreateObject("Scripting.Dictionary")
  
  '# Populate the dictionary with existing column names.  Used later to check if a column exists already before adding it
  Dim col As ListColumn
  
  For Each col In oldTable.ListColumns
      oldDict.Add col.Name, col
  Next col
  
  For Each col In newTable.ListColumns
      newDict.Add col.Name, col
  Next col
  
  '# Set lcID for use later
  Set lcID = newTable.ListColumns("ID")
  
  
  '--------------------------------------------------------------------------------------------------------
  '## STEP 1 Create ID column with hyperlinks
  '--------------------------------------------------------------------------------------------------------

  If addIdLinksColumn = True Then
    Call CreateIdLinks '>>
  End If

  
  '--------------------------------------------------------------------------------------------------------
  '## STEP 2: Update the new table, using (step 1a) the formulaColumns passed in and (step 1b) textColumns
  '--------------------------------------------------------------------------------------------------------

  '--------------------------------------------------------------------------------------------------------
  '## STEP 2A Formula columns
  '--------------------------------------------------------------------------------------------------------
  
  '# Check there are values in the array before doing anything
  If Not IsEmpty(formulaColumns) Then
    For Each columnName In formulaColumns
        
      'Debug.Print "SyncTableData > columnName: " & columnName
        
      Set lcColumnName = Nothing
                          
      '# If the column exists already, use it, otherwise add it and use the new one (also add it to the scripting dictionary)
      If newDict.Exists(columnName) Then
        Set lcColumnName = newDict(columnName)
      Else
        Set lcColumnName = newTable.ListColumns.Add
        lcColumnName.Name = columnName
        newDict.Add lcColumnName.Name, lcColumnName
      End If
              
      '# If the column exists in the old table, set the same formula (otherwise do nothing but note in console)
      If oldDict.Exists(columnName) Then
        lcColumnName.DataBodyRange.Formula2R1C1 = _
          oldTable.ListColumns(columnName).DataBodyRange.Formula2R1C1
      Else
        Debug.Print "SyncTableData: column doesn't exist in old table - " & columnName
      End If
      
      lcColumnName.Range(1).Interior.Color = RGB(21, 96, 130)
      lcColumnName.Range.EntireColumn.autoFit
      
    Next columnName
  
  End If


  '--------------------------------------------------------------------------------------------------------
  '## STEP 2B Text columns (uses same concept as formula columns, but replaces with values at the end)
  '--------------------------------------------------------------------------------------------------------
  
  '# Check there are values in the array before doing anything
  If Not IsEmpty(textColumns) Then
  
    For Each columnName In textColumns
    
      'Debug.Print "SyncTableData > columnName: " & columnName
        
      Set lcColumnName = Nothing
                
      '# If the column exists already, use it, otherwise add it and use the new one (also add it to the scripting dictionary)
      If newDict.Exists(columnName) Then
        Set lcColumnName = newDict(columnName)
      Else
        Set lcColumnName = newTable.ListColumns.Add
        lcColumnName.Name = columnName
        newDict.Add lcColumnName.Name, lcColumnName
      End If
            
            
      '# If the column exists in the old table: add formula to look up the same ID and column name to find the previous value in the old table (or otherwise blank)
      If oldDict.Exists(columnName) Then
        lcColumnName.DataBodyRange.Formula2R1C1 = _
          "=LET(PrevVal,XLOOKUP([@ID]," & oldTable.Name & "[ID]," & oldTable.Name & "[" & columnName & "],"""")," & Chr(10) & "IF(PrevVal="""","""",PrevVal)" & Chr(10) & ")"
      Else
        Debug.Print "SyncTableData: column doesn't exist in old table - " & columnName
      End If
      
      '# Replace formulas with values, and format
      lcColumnName.DataBodyRange.value = lcColumnName.DataBodyRange.value
      lcColumnName.Range(1).Interior.Color = RGB(21, 96, 130)
      lcColumnName.Range.EntireColumn.autoFit
      
    Next columnName

  End If
  
  
  If comparisonColumn <> "" Then

  '--------------------------------------------------------------------------------------------------------
    '## STEP 3: Add "Added" and "Removed" formulas
  '--------------------------------------------------------------------------------------------------------
    Dim lcChangeStatusNew As ListColumn, lcChangeStatusOld As ListColumn
    
    ' Add "ChangeStatus" column to the new table
    Set lcChangeStatusNew = newTable.ListColumns.Add
    lcChangeStatusNew.Name = "ChangeStatus"
    '# Add a formula that checks if the ID existed in the old table (will show "Added" if not), or if the comparisonColumn from modConfig has changed (will show old and new vals)
    lcChangeStatusNew.DataBodyRange.Formula2R1C1 = _
      "=LET(oldVal,XLOOKUP([@ID]," & oldTable.Name & "[ID]," & oldTable.Name & "[" & comparisonColumn & "],""NotFound"")," & Chr(10) & "  IF([@[" & comparisonColumn & "]]=oldVal,""""," & Chr(10) & "  IF(oldVal=""NotFound"",""Added""," & Chr(10) & "  ""Release: "" & oldVal & "" > "" & [@[" & comparisonColumn & "]]))" & Chr(10) & ")"
        
          '# NB: ends up like this (where "Key Col" is the name of a column where I'm checking if the value has changed:
            '=LET(oldVal,XLOOKUP([@ID],tblOld3[ID],tblOld3[Key Col],"NotFound"),
            '  IF([@[Key Col]]=oldVal,"",
            '  IF(oldVal="NotFound","Added",
            '  "Release: " & oldVal & " > " & [@[Key Col]]))
            ')
          
      
  '    "=IF(ISERROR(MATCH([@" & lcID.Name & "]," & oldTable.Name & "[ID],0)),""Added"","""")"
    lcChangeStatusNew.DataBodyRange.value = lcChangeStatusNew.DataBodyRange.value
    lcChangeStatusNew.Range(1).Interior.Color = RGB(21, 96, 130)
    lcChangeStatusNew.Range.EntireColumn.autoFit
    
    '# If a comparisonColumn string was passed in...
    If createChangeLog = True Then
      '# Add "Added" rows from newTable to change log
      Call UpdateChangeLog(newTable)
    End If
  
    '# Add "ChangeStatus" column to the old table
    If oldDict.Exists("ChangeStatus") Then
      Set lcChangeStatusOld = oldTable.ListColumns("ChangeStatus")
    Else
      Set lcChangeStatusOld = oldTable.ListColumns.Add
      lcChangeStatusOld.Name = "ChangeStatus"
      oldDict.Add lcChangeStatusOld.Name, lcChangeStatusOld
    End If
    
    lcChangeStatusOld.DataBodyRange.Formula2R1C1 = _
      "=IF(ISERROR(MATCH([@ID]," & newTable.Name & "[" & lcID.Name & "],0)),""Removed"","""")"
    
    lcChangeStatusOld.DataBodyRange.value = lcChangeStatusOld.DataBodyRange.value
    lcChangeStatusOld.Range(1).Interior.Color = RGB(21, 96, 130)
    lcChangeStatusOld.Range.EntireColumn.autoFit
    
    If createChangeLog = True Then
      Set tblChgLog = Sheets("Change Log").ListObjects(1)
      ' Add "Removed" rows from oldTable to change log
      Call UpdateChangeLog(oldTable)
    End If
  
  End If

  ' Clean up
  Set oldDict = Nothing
  Set newDict = Nothing
  
End Sub

