Sub TbSetup()
  
  Dim lc As ListColumn
  
  'If Not Intersect(ActiveCell, ActiveSheet.ListObjects(1).Range) Is Nothing Then     '' prob not useful, only noting as another way to check current cell in a table
  'If Not Intersect(ActiveCell, [Table1]) Is Nothing Then                              '' same as above, except only refers to DataBodyRange rather than Range so doesn't include header
  
  If ActiveSheet.ListObjects.count = 1 Then           '' if there is only one table in the sheet, use it
      Set tb = ActiveSheet.ListObjects(1)
      
  ElseIf Not ActiveCell.ListObject Is Nothing Then    '' if the current cell is in a table, use it
      Set tb = ActiveCell.ListObject
      
  Else                                                ''error message, stop
    Debug.Print "TbSetup needs either a single table, or the active cell to be in a table"
    End
    
  End If
   
  '# Set lcs as an object with the table list columns
   Set lcs = tb.ListColumns
   
  '' Use my module level variables to make various attributes of the table available to other procedures
      '' (NB: they persist, so care with using them again without calling TbSetup first)
  
  tb_HeaderRow = Range(tb & "[#Headers]").Rows(1).row                 '' first (header) row number
  tb_BodyFirstRow = Range(tb).Rows(1).row '                           '' first (databody) row number
  tb_LastRow = Range(tb).Rows(Range(tb).Rows.count).row               '' last row number
  tb_FirstCol = Range(tb).Columns(1).Column                           '' first column number
  tb_LastCol = Range(tb).Columns(Range(tb).Columns.count).Column      '' last column number
  tb_ActiveCellColName = Cells(tb_HeaderRow, ActiveCell.Column).value '' table column name for the current cell
  
  If tb_ActiveCellColName <> "" Then
      Set lc_Current = tb.ListColumns(tb_ActiveCellColName)             '' current column (reference to the actual list column). Use 'Set' to assign an object ref to this variable (i.e. I think a column is an object)
  End If
  
  Set lc_First = tb.ListColumns(1)
  
  '# By default set lc_ID to the first column. _
      If can find "ID (Link)" - use that and jump to end of this section.  Otherwise repeat with "ID" if not. Otherwise keep default (first column)
  
  Set lc_ID = lc_First
  For Each lc In tb.ListColumns
      If lc.Name = "ID (Link)" Then
          Set lc_ID = lc
          GoTo idDefined
          Exit For
      End If
  Next
  If lc_ID = lc_First Then
      For Each lc In tb.ListColumns
          If lc.Name = "ID" Then
              Set lc_ID = lc
              GoTo idDefined
              Exit For
          End If
      Next
  End If
  
idDefined:

  
  Set tbDict = CreateObject("Scripting.Dictionary") ' Initialize the dictionary
  
  For Each lc In tb.ListColumns
      tbDict.Add lc.Name, lc
  Next lc


'Debug.Print tb_HeaderRow, tb_BodyFirstRow, tb_LastRow, tb_FirstCol, tb_LastCol, tb_ActiveCellColName
 
''Example usage------------------
'Range(tb & "[[Date Time]:[Column2]]").Value = tblData
'Range("tblDailySummaryUsers[[#All],[Username]:[PrimarySmtp]]").Select
'tb.ListColumns("ComputerName").Range.Column  'NB: the actual column. e.g. if the table starts in column B, and this is column D, will be 4
'tb.ListColumns("ComputerName").Index   'NB: relative to table, e.g. if the table starts in column B, and this is column D, will be 3
 
End Sub

Sub TbSort(col1 As String, Optional order1 As XlSortOrder = xlAscending, Optional col2 As String = "", Optional order2 As XlSortOrder = xlAscending)

  '# Most simple option - pass in name of column to sort ascending.  Can optionally change sort order, and add a secondary sort column
  
  With tb.Sort
    .SortFields.Clear

    '# Add first sort key
    .SortFields.Add2 key:=Range(tb.Name & "[" & col1 & "]"), _
                     SortOn:=xlSortOnValues, _
                     Order:=order1, _
                     DataOption:=xlSortNormal

    '# Optionally add second sort key
    If Len(col2) > 0 Then
      .SortFields.Add2 key:=Range(tb.Name & "[" & col2 & "]"), _
                       SortOn:=xlSortOnValues, _
                       Order:=order2, _
                       DataOption:=xlSortNormal
    End If

    '# General sort options
    .Header = xlYes
    .MatchCase = False
    .Orientation = xlTopToBottom
    .SortMethod = xlPinYin
    .Apply
  End With

End Sub

