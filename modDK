Sub LrSetBorder(target As Variant, Optional bType As XlBordersIndex = -1, Optional bWeight As XlBorderWeight = xlThin, _
    Optional bColour As XlRgbColor = rgbBlack, Optional clearBorders As Boolean = True)
    
  '#If no bType passed in, will just clear borders for the range
  '# NB: at this stage it's easier to run multiple times if changing other borders.

  Dim rng As Range

  '# If a range was passed in, uses that.  If not, assumes it's something like a lr where it can simply make that `lr.Range`
  If TypeOf target Is Range Then
    Set rng = target
  Else
    Set rng = target.Range
  End If


  '# Optionally clear all borders on the range
  If clearBorders Then
    Dim b As XlBordersIndex
    For b = xlEdgeLeft To xlInsideHorizontal  '# NB: excludes diagonals but that's fine
      With rng.Borders(b)
        .LineStyle = xlLineStyleNone
      End With
    Next b
  End If

  '# If a specific border is provided, apply it
  If bType >= xlEdgeLeft And bType <= xlInsideHorizontal Then
    With rng.Borders(bType)
      .LineStyle = xlContinuous
      .Color = bColour
      .Weight = bWeight
    End With
  End If
  
  Exit Sub '# EXAMPLE USAGE: ----------------------------------

  Dim lr As ListRow
  
  TbSetup
  
  For Each lr In tb.ListRows
      
    If TbCellVal(lr, "cc") = "xyz" Then
      LrSetBorder lr, xlEdgeTop, xlMedium, rgbRed
    End If
    
  Next

End Sub

