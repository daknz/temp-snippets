Else
    Call filterTable(tb, lc_Current, ContainsSingle, filterValue)

    End If


End Sub

Private Sub filterTable(tb, lc, fType As filterType, Optional fText As Variant, Optional combineFilters As Boolean)
'' Call from another procedure .. filterColumn` often calls this, and see bottom of this procedure for other examples
''NB: can't remember plan for combineFilters parameter - either mult columns or mult criteria within a column? Hadn't done
''Uses Enum filterType in module declarations

'Debug.Print "filterTable: ", "lc=" & lc, "fType=" & fType 'NB: fType show a number for the Enum (first is 0)

Select Case fType
    Case filterType.Blanks
        tb.Range.AutoFilter field:=lc.Index, Criteria1:=""

    Case filterType.NonBlanks
        tb.Range.AutoFilter field:=lc.Index, Criteria1:="<>"
    
    Case filterType.EqualsSingle
        tb.Range.AutoFilter field:=lc.Index, Criteria1:=fText
    
    Case filterType.EqualsMultiple 'Eg. filter where value equals "aa" OR "bb" (use array - see examples at the bottom)
        tb.Range.AutoFilter field:=lc.Index, Criteria1:=fText, Operator:=xlFilterValues  'Seems to need 'xlFilterValues' to work
    
    Case filterType.ContainsSingle
        tb.Range.AutoFilter field:=lc.Index, Criteria1:="*" & fText & "*"
    
    Case filterType.ContainsMultiple
        Debug.Print "Not sure how to to yet, other than 'manually' with value 1 or value 2 (i.e. can't do more like EqualsMultiple"
        'tb.Range.AutoFilter Field:=lc.Index, Criteria1:="-*" & fText & "*", Operator:=xlFilterValues    'Tried same style as EqualsMultiple
        'tb.Range.AutoFilter Field:=lc.Index, Criteria1:="=*b1*", Operator:=xIOr, Criteria2:="=*b2*"         'Recorded
        'tb.Range.AutoFilter Field:=lc.Index, Criterial:="=b1", Operator:=xIOr, Criteria2:="=b2"            'Recorded "equals 'b1' or 'b2'", which comes out in a different style to what I landed on for EqualsMultiple so not helping
    
    Case filterType.NotContains
        tb.Range.AutoFilter field:=lc.Index, Criteria1:="<>*" & fText & "*"
    
    Case Else
        Debug.Print "Unknown"
End Select

