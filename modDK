Sub macrosList()
''Ctrl+m

  With frmActions
    
    '---------------------------------------------------------------------------------------
    '## Display the form
    '---------------------------------------------------------------------------------------
    .Show

    '---------------------------------------------------------------------------------------
    '## Run macro using the selected macro name/parameter when the form is closed
    '---------------------------------------------------------------------------------------
    
    If .macroName = "" Then Exit Sub  '# I.e. if form was cancelled
    
    If IsNull(.macroParameter) Then
      ' No parameter; call the macro without arguments
      Application.Run .macroName
    Else
      ' Call the macro with a parameter
      Application.Run .macroName, .macroParameter
    End If
  
  End With
  
  '---------------------------------------------------------------------------------------
  '## Remove the form from memory
  '---------------------------------------------------------------------------------------
  Unload frmActions

End Sub

Sub goToPrompt()

  With frmSelect
     
    '---------------------------------------------------------------------------------------
    '## Display the form
    '---------------------------------------------------------------------------------------
    Call .InitializeForm("Go To")
    .Show
    
    
    '---------------------------------------------------------------------------------------
    '## Take action with selected item when the form is closed
    '---------------------------------------------------------------------------------------
    If .resultType = "Workbook" Then
    
      With .selectedItem
'        Debug.Print "goToPrompt: .Name: "; .Name
        Windows(.Name).Visible = True   '* not currently catering for hidden workbooks, but should deal with it when it does
        .Activate
      End With
      
    ElseIf .resultType = "Worksheet" Then
    
      With .selectedItem
        .Visible = True
        .Select
      End With
      
    ElseIf .resultType = "Column" Then
    
      With .selectedItem
        'Debug.Print "modDK > goToPrompt > [...?]: " & .Index
        .Range.EntireColumn.Hidden = False
        Cells(Selection.row, .Range.Column).Select
        ActiveWindow.ScrollColumn = .Index
      End With
      
    ElseIf .resultType = "Cell" Or .resultType = "ID" Then
      If Not frmSelect.selectedCell Is Nothing Then         '* Currently can't happen as form won't hide in this scenario - see which is best approach
        frmSelect.selectedCell.Select
      End If
    
    Else
          
    End If

  End With
   
  '---------------------------------------------------------------------------------------
  '## Remove the form from memory
  '---------------------------------------------------------------------------------------

  Unload frmSelect
  Set frmSelect = Nothing '(AI: Interacting with the form while it's being unloaded can cause unpredictable behavior. Ensure that all references to the form are cleared after Unload frmGoTo2)
  
