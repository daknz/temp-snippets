Sub copySheet(Optional newWorkbook As Boolean)

  '# Currently set up so if run with no param, will copy current sheet after itself.  If True passed in, will prompt for another workbook/sheet and MOVE it before there
  '* Are other variations I could have, e.g. for now have commented out the "Copy to a new workbook" option

  If newWorkbook <> True Then
  
    ''Copy after the current sheet, and just rename with '2' at the end not '(2)' which can affect TbSetup
    ActiveSheet.Copy after:=Sheets(ActiveSheet.Index)
'    ActiveSheet.Name = Replace(ActiveSheet.Name, "(2)", "2")

  Else

    '# Copy to a new workbook
    'ActiveSheet.Copy
    
    Dim wkbk As Workbook, wksh As Worksheet
  
    '-------------------
    '# Get the workbook
    '-------------------
    With frmSelect
      Call .InitializeForm("Move Sheet: other workbook", "Workbook") '>>
      .Show
      
      '#Outcome after close form
      If .resultType = "Workbook" Then
        Set wkbk = .selectedItem
      Else
        Debug.Print "copySheet: no valid workbook returned, no action taken"
        GoTo CancelFlow
      End If
  
    End With
    
    Unload frmSelect
    Set frmSelect = Nothing
  
    
    '-------------------
    '# Get the worksheet
    '-------------------
    
    Set sheetsCollection = GetSheets("visible", wkbk)
  
    ' Extract the results
    sheetsArray = sheetsCollection("SheetsArray")
    'Set parentWorkbook = sheetsCollection("ParentWorkbook")
    
    'Debug.Print "insertFormula_XLOOKUP2 > IsArrayPopulated(sheetsArray): "; IsArrayPopulated(sheetsArray)
  
    
    With frmSelect
    
      'Debug.Print "parentWorkbook.Name: "; parentWorkbook.Name; " [insertFormula_XLOOKUP2]"
  '    Call .InitializeForm("XLOOKUP: other worksheet", "Worksheet", sheetsArray, parentWorkbook) '>>
      Call .InitializeForm("Move Sheet: other worksheet", "Worksheet", sheetsArray) '>>
      .Show
  
      '#Outcome after close form
      If .resultType = "Worksheet" Then
        Set wksh = .selectedItem
        'MsgBox "insertFormula_XLOOKUP2: " & vbCr & vbCr & _
          "Workbook: " & wkbk.Name & vbCr _
          & "Worksheet: " & wksh.Name & vbCr _
          & "Worksheet parent: " & wksh.Parent.Name
      Else
        Debug.Print "copySheet: no valid worksheet returned, no action taken"
        GoTo CancelFlow
      End If
    
    End With
    
    Unload frmSelect
    Set frmSelect = Nothing
    
    ActiveSheet.Move Before:=Workbooks(wkbk.Name).Sheets(wksh.Index)

  End If

  Exit Sub '----------------------------------------------
CancelFlow:
  Unload frmSelect
  Set frmSelect = Nothing

End Sub

