End Sub
Sub sbGetQueryContent()

'# Turn a table into (part of) SQL query based on visible columns and rows

Dim cRow, rowVals, outputVals, headerRow As Boolean
Dim rw As ListRow, col As ListColumn

TbSetup

cRow = ""  '# Initialize cRow to detect first row

'# --- Process header row ---
rowVals = ""
headerRow = True
For Each col In tb.ListColumns
    If Not col.Range.EntireColumn.Hidden Then
        rowVals = rowVals & sbCellOutput(col.Range.Cells(1, 1), headerRow) & ", "
    End If
Next col

'# Add header row to output
If Len(rowVals) > 0 Then
    rowVals = "(" & Left(rowVals, Len(rowVals) - 2) & ")"
    outputVals = rowVals
End If

'# --- Loop through table data rows ---
headerRow = False
For Each rw In tb.ListRows
    rowVals = ""
    For Each col In tb.ListColumns
        If Not col.Range.EntireColumn.Hidden Then
            rowVals = rowVals & sbCellOutput(rw.Range.Cells(1, col.Index), headerRow) & ", "
        End If
    Next col
    
    '# Skip adding empty rows (e.g. only hidden columns)
    If Len(rowVals) > 0 Then
        rowVals = "(" & Left(rowVals, Len(rowVals) - 2) & ")"
        outputVals = outputVals & vbLf & rowVals & ","
    End If
Next rw

'# Copy to clipboard (needs Tools > References: Forms 2.0 Object Library ticked)
With New DataObject
    .SetText outputVals
    .PutInClipboard
End With

End Sub


Function sbCellOutput(c, headerRow As Boolean)

If headerRow = True Then
  
  sbCellOutput = c

Else
  If c.value = "" Then
    sbCellOutput = "NULL"
  ElseIf IsNumeric(c.value) Then
    sbCellOutput = c
  Else
    sbCellOutput = "'" & c & "'"
  End If

End If

End Function

Sub sbGenerateUpdateSQL_Dynamic()
'# Generates SQL UPDATE ... CASE from visible table columns, with flexible ID and target column

'# NB: use and 'id' column and another column defined in targetColName below
'# I.e. isn't like the other one that goes off visible rows/columns

Dim rw As ListRow, col As ListColumn
Dim tblName As String, idColName As String, targetColName As String
Dim idVal As String, targetVal As String
Dim sql As String
Dim rowVals As String

'# --- Configuration: set the column names -----------------------------------
tblName = "players"
idColName = "id"       '# change this to your ID column
targetColName = "rank" '# change this to whichever column you want to update
'# ---------------------------------------------------------------------------

TbSetup

sql = "UPDATE " & tblName & vbCrLf & "SET " & targetColName & " = CASE " & idColName & vbCrLf
rowVals = ""

'# Loop through table rows
For Each rw In tb.ListRows
    '# Skip hidden rows
    If rw.Range.EntireRow.Hidden = False Then
        idVal = ""
        targetVal = ""
        
        '# Loop visible columns to find ID and target values
        For Each col In tb.ListColumns
            If Not col.Range.EntireColumn.Hidden Then
                If col.Name = idColName Then
                    idVal = rw.Range.Cells(1, col.Index).value
                ElseIf col.Name = targetColName Then
                    'targetVal = rw.Range.Cells(1, col.Index).Value
                    targetVal = sbCellOutput(rw.Range.Cells(1, col.Index), False)
                End If
            End If
        Next col
        
        '# Only include if both values exist (skip blank target)
        If Trim(targetVal & "") <> "" And Trim(idVal & "") <> "" Then
            sql = sql & "  WHEN " & idVal & " THEN " & targetVal & vbCrLf
            rowVals = rowVals & idVal & ", "
        End If
    End If
Next rw

'# Finish SQL statement
sql = sql & "END" & vbCrLf
sql = sql & "WHERE " & idColName & " IN (" & Left(rowVals, Len(rowVals) - 2) & ");"

'# Copy to clipboard
With New DataObject
    .SetText sql
    .PutInClipboard
End With

'MsgBox "SQL UPDATE copied to clipboard!"
End Sub



