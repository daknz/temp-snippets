Function GetTextBetweenQuotesAfterHyperlink(formulaText As String) As String
  '# Find text between the first pair of quotes after 'HYPERLINK'

  Dim startPos As Long
  Dim firstQuote As Long
  Dim secondQuote As Long
  
  startPos = InStr(1, formulaText, "HYPERLINK", vbTextCompare)
  If startPos = 0 Then Exit Function
  
  firstQuote = InStr(startPos, formulaText, """")
  secondQuote = InStr(firstQuote + 1, formulaText, """")
  
  If firstQuote > 0 And secondQuote > 0 Then
    GetTextBetweenQuotesAfterHyperlink = Mid(formulaText, firstQuote + 1, secondQuote - firstQuote - 1)
  End If

End Function

Function GetHyperlinkFormulaURL(cell As Range) As String
    
    Dim f As String, pos As Long, startPos As Long, commaPos As Long
    Dim arg As String
    
    GetHyperlinkFormulaURL = ""
    
    If Not cell.HasFormula Then Exit Function
    
    f = cell.Formula
    
    startPos = InStr(1, UCase(f), "HYPERLINK(") + Len("HYPERLINK(")
    commaPos = InStr(startPos, f, ",")
    
    arg = Mid$(f, startPos, commaPos - startPos)
    arg = Trim(arg)
    Debug.Print arg
    
    GetHyperlinkFormulaURL = cell.Parent.Evaluate("=" & arg)

End Function



