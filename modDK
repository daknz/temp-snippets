Sub TbCreate()
'Ctrl+t
'# Creates a table, unless one already exists in which case will rename/reformat like a new table.  Runs TbSetup at the end.

Dim tblName, freezeCols As Boolean, autoFitCols As Boolean

'' -- Boolean options - not sure on preference yet ----
autoFitCols = 1
'' ----------------------------------------------------

''Cell/sheet styling
With Cells
    .Font.Name = "Segoe UI"
    .Font.Size = 10
    .VerticalAlignment = xlTop
End With
ActiveWindow.DisplayGridlines = False


'# Define the table name from the sheet name
tblName = "tbl" & StripNonAlphanumeric(ActiveSheet.Name)


'# If there is no table in the sheet, create one
If ActiveSheet.ListObjects.count = 0 Then
    ActiveSheet.ListObjects.Add(xlSrcRange, ActiveSheet.UsedRange, , xlYes).Name = tblName
'# If there is a table in the sheet, refer to that for the rest
ElseIf ActiveSheet.ListObjects.count = 1 Then
    ActiveSheet.ListObjects(1).Name = tblName
End If
    

With ActiveSheet.ListObjects(tblName)
    .TableStyle = "TableStyleLight11"       ''9 = blue, 11 = gray (for gray: use also the section below to make header black)
    .ShowTableStyleColumnStripes = True
End With

''Black header (use with TableStyleLight11 above which has grey border but also grey shading
With Range(tblName & "[#Headers]").Interior
    .Pattern = xlSolid
    .PatternColorIndex = xlAutomatic
    .ThemeColor = xlThemeColorLight1
End With


Cells(1, ActiveCell.Column).Select          ' to ensure frozen top row is in the correct place, and retain the column selection for column freezing

With ActiveWindow
    .SplitColumn = 0
    .SplitRow = 1
End With
ActiveWindow.FreezePanes = True

If autoFitCols = True Then
    Cells.EntireColumn.autoFit
End If

TbSetup

End Sub
