Sub freezeCells()

If ActiveCell.row = 1 And ActiveCell.Column = 1 Then
    ''No split (so also no freeze)
    
    With ActiveWindow
        .SplitColumn = 0
        .SplitRow = 0
    End With
    
Else
    ''Split above and left of current cell then freeze
    ActiveWindow.SplitColumn = ActiveCell.Column - 1
    ActiveWindow.SplitRow = ActiveCell.row - 1
    ActiveWindow.FreezePanes = True
End If

End Sub

Sub insertFormula_MATCH()
  
  '# First checks if the current cell has a MATCH formula (assumes the final "0" parameter not added either i.e. to be quicker .. this will add it, which gives slightly different results, but what I want)
      '# If so: adds "IF(ISERROR..." etc, i.e. so the result shows "No" for errors or blank
  '# Otherwise adds a 'MATCH' formula (with ISERROR wrapper) that checks if ID in this table exists in another
  '# Prompts for which sheet the other table is in first (only within the same spreadsheet)
  '# Currently needs to use ID columns (based on lc_ID in TbSetup ... i.e. has a few options)
  
  Dim colNameThis, colNameOther, defaultIndex, shThis, shOthersCount, shIndex, shList, sh As Worksheet
  
  '# If the cell already has a MATCH formula, will expand the formula to add the 'wrapper' around it
  If InStr(1, ActiveCell.Formula2R1C1, "MATCH", vbTextCompare) = 2 Then
      
      '# Adds a bit at the front and the end of the existing formula (first stripping the initial "=" and final ")"
      ActiveCell.Formula2R1C1 = _
          "=IF(ISERROR(" & _
          Left(Right(ActiveCell.Formula2R1C1, Len(ActiveCell.Formula2R1C1) - 1), Len(ActiveCell.Formula2R1C1) - 2) & _
          ", 0)), ""No"", """")"
      
      Exit Sub '--------------------
      
  End If
  
  
  '# Capture this sheet so can return to it later, and define the ID column within it
  Set shThis = ActiveSheet
  TbSetup
  colNameThis = lc_ID.Name


  Set sheetsCollection = GetSheets("withTable")
  ' Extract the results
  sheetsArray = sheetsCollection("SheetsArray")

  With frmSelect
    Call .InitializeForm("MATCH: other sheet", "Worksheet", sheetsArray) '>>

    .Show
    .TextBox1.SetFocus ' Ensure focus
  
    
    '#Outcome after close form
    If .resultType = "Worksheet" Then
          
      '# Go to the selected sheet, define the ID column to look up
      .selectedItem.Activate
      TbSetup
      colNameOther = lc_ID.Name
      
      '# Return to the original sheet
      shThis.Activate
      
      '# Add a formula in this format (in this example it's looking up 'ID' in this table and 'ID (Link)' in the other _
          =IF(ISERROR(MATCH([@ID], tblSheet2[ID (Link)], 0)), "No", "")
      ActiveCell.FormulaR1C1 = _
          "=IF(ISERROR(MATCH([@[" & colNameThis & "]]," & tb & "[" & colNameOther & "], 0)), ""No"", """")"
    
    End If

  End With
  
  Unload frmSelect
  Set frmSelect = Nothing '(AI: Interacting with the form while it's being unloaded can cause unpredictable behavior. Ensure that all references to the form are cleared after Unload frmGoTo2)


End Sub


Sub insertFormula_XLOOKUP(Optional ThisWorkbook As Boolean = True)
  '# Basic example that assumes using 'ID' column in both.
  '# By default it assumes this workbook.  If False is passed in then will prompt for the workbook. NB: for this workbook Excel will naturally strip it from the final formula.

  Dim sheetsCollection As Collection, sheetsArray As Variant, parentWorkbook As Workbook
  Dim columnsCollection As Collection, columnsArray As Variant, parentWorksheet As Worksheet
  Dim headerCell As Range

  On Error GoTo ErrorHandler

  Dim wkbk As Workbook, wksh As Worksheet, lc As ListColumn
  
  
  If ThisWorkbook = True Then
    
    Set wkbk = ActiveWorkbook
  
  Else
    
    '-------------------
    '# Get the workbook
    '-------------------
    With frmSelect
      Call .InitializeForm("XLOOKUP: other workbook", "Workbook") '>>
      .Show
      
      '#Outcome after close form
      If .resultType = "Workbook" Then
        Set wkbk = .selectedItem
      Else
        Debug.Print "insertFormula_XLOOKUP: no valid workbook returned, no action taken"
        GoTo CancelFlow
      End If
  
    End With
    
    Unload frmSelect
    Set frmSelect = Nothing
  
  End If
  
  
  '-------------------
  '# Get the worksheet
  '-------------------
  
  Set sheetsCollection = GetSheets("withTable", wkbk)

  ' Extract the results
  sheetsArray = sheetsCollection("SheetsArray")
  Set parentWorkbook = sheetsCollection("ParentWorkbook")
  
'  Debug.Print "insertFormula_XLOOKUP > IsArrayPopulated(sheetsArray): "; IsArrayPopulated(sheetsArray)

  
  With frmSelect
  
    Debug.Print "parentWorkbook.Name: "; parentWorkbook.Name; " [insertFormula_XLOOKUP2]"
'    Call .InitializeForm("XLOOKUP: other worksheet", "Worksheet", sheetsArray, parentWorkbook) '>>
    Call .InitializeForm("XLOOKUP: other worksheet", "Worksheet", sheetsArray) '>>
    .Show

    '#Outcome after close form
    If .resultType = "Worksheet" Then
      Set wksh = .selectedItem
    Else
      Debug.Print "insertFormula_XLOOKUP: no valid worksheet returned, no action taken"
      GoTo CancelFlow
    End If
  
  End With
  
  Unload frmSelect
  Set frmSelect = Nothing
  
  
  '-------------------
  '# Get the table column
  '-------------------
  
  Set columnsCollection = GetColumns("", wksh)
  
  ' Extract the results
  columnsArray = columnsCollection("ColumnsArray")
  Set parentWorksheet = columnsCollection("ParentWorksheet")
'  Debug.Print "insertFormula_XLOOKUP > IsArrayPopulated(columnsArray): "; IsArrayPopulated(columnsArray)

  
  With frmSelect
  
    Debug.Print "parentWorksheet.Name: "; parentWorksheet.Name; " [insertFormula_XLOOKUP]"
'    Call .InitializeForm("XLOOKUP: lookup column", "Column", columnsArray, parentWorksheet) '>>
    Call .InitializeForm("XLOOKUP: lookup column", "Column", columnsArray) '>>
    .Show

    '#Outcome after close form
    If .resultType = "Column" Then
      Set lc = .selectedItem
    Else
      Debug.Print "insertFormula_XLOOKUP: no valid column returned, no action taken"
      GoTo CancelFlow
    End If
  
  End With
  
  Unload frmSelect
  Set frmSelect = Nothing
  
  
  '---------------------
  'Enter XLOOKUP formula
  '---------------------
  
'  ActiveCell.FormulaR1C1 = _
    "=XLOOKUP([@ID],Book3!tblSheet3[ID],Book3!tblSheet3[Stuff],"""")"
  
  ActiveCell.FormulaR1C1 = _
    "=XLOOKUP([@ID],'" & wkbk.Name & "'!" & wksh.ListObjects(1).Name & "[ID],'" & wkbk.Name & "'!" & wksh.ListObjects(1).Name & "[" & lc.Name & "],"""")"
  
  Set headerCell = Cells(ActiveSheet.ListObjects(1).HeaderRowRange.row, ActiveCell.Column)
  If Left(headerCell.value, 6) = "Column" Then
    headerCell.value = lc.Name
  End If
  
  '-----------------------
  Exit Sub  '# Other flows
  '-----------------------
    
CancelFlow:

  Unload frmSelect
  Set frmSelect = Nothing
  Exit Sub '----------------------------------------------
  
  
ErrorHandler:
  LogError Err.Number, Err.Description
  If Err.Number <> 0 Then
    ' Re-raise the error to show the built-in error dialog
    Err.Raise Err.Number
  End If

End Sub

