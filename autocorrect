Sub autoCorrectBulkUpdateAllLanguages()
languageslist = Array(wdEnglishUS, wdEnglishAUS, wdEnglishNewZealand)
'# NB: not sure there is need for NZ, seems to use AUS for autocorrect when select NZ, but no harm (though does cause an issue with deleting)

For Each lang In languageslist

    ActiveDocument.Styles(wdStyleNormal).LanguageID = lang
    ActiveDocument.Content.LanguageID = lang
    autoCorrectBulkUpdate ("add")
'    autoCorrectBulkUpdate ("delete")
    
Next

End Sub

Sub autoCorrectBulkUpdate(updateType As String)
'# Run from autoCorrectBulkUpdateAllLanguages (instead of needing to select all then Review > Language > Switch Proofing Language for each)
'# Can set updateType to "add" or "delete" depending which need to do
'# Assumes list is in a 2-column table (no headers)

Dim tbl As Table
Dim r As Long
Dim trigger As String
Dim replacement As String

' # assume the first table in the document holds the data
Set tbl = ActiveDocument.Tables(1)

For r = 1 To tbl.Rows.Count

trigger = Trim(Replace(tbl.Cell(r, 1).Range.Text, Chr(13) & Chr(7), ""))
replacement = Trim(Replace(tbl.Cell(r, 2).Range.Text, Chr(13) & Chr(7), ""))

If trigger <> "" Then
    
  If updateType = "add" Then
    On Error Resume Next
      AutoCorrect.Entries.Add Name:=trigger, Value:=replacement
    On Error GoTo 0
  ElseIf updateType = "delete" Then
    On Error Resume Next
      AutoCorrect.Entries(trigger).Delete
    On Error GoTo 0
  End If
      
End If

Next r

End Sub
