Private Sub UserForm_Initialize()
  '# Called automatically when form loaded into memory (before it is shown). Can't pass parameters to it
  '# NB: is also used by UserForm_KeyPress, so care when adding anything here in case it affects that
  
  With Me
    .Width = 300
    .Height = 400
  End With

  With Label1
    .Left = 10
    .Top = 10
    .Width = Me.Width - 30
    .Height = 200
    .Visible = True
    .Font = "Segoe UI"
    .Caption = "Select an option: " & vbNewLine & vbNewLine & _
      "w:" & vbTab & "Workbook" & vbNewLine & _
      "s:" & vbTab & "workSheet" & vbNewLine & _
      "c:" & vbTab & "Column" & vbNewLine & _
      "r:" & vbTab & "cell Ref" & vbNewLine & _
      "d:" & vbTab & "Date" & vbNewLine & _
      "i:" & vbTab & "ID" & vbNewLine & _
      ""
  End With

  With TextBox1
    .Left = 10
    .Top = Label1.Top + Label1.Height
    .Width = Me.Width - 30
    .Font = "Segoe UI"
    .Visible = False    ' So initial keypress event will work
  End With

  With ListBox1
    .Left = TextBox1.Left
    .Width = TextBox1.Width
    .Top = TextBox1.Top + TextBox1.Height
    .Height = 300
    .Font = "Segoe UI"
    .Visible = False    ' So initial keypress event will work
  End With

End Sub

Public Sub InitializeForm(frmCaption As String, Optional initialResultType As String = "", Optional ByVal initialItemsArray As Variant = Empty, Optional parentWorkbook As Workbook, Optional parentWorksheet As Worksheet)
  '# Custom of my own, called from calling module (TO DO)
  
  Dim sheetsCollection As Collection, columnsCollection As Collection
  
  Me.Caption = frmCaption
  
  Me.resultType = initialResultType
  
'  Debug.Print "frmSelect > InitializeForm > IsEmpty(initialItemsArray): " & IsEmpty(initialItemsArray)
'  Debug.Print "frmSelect > InitializeForm > Me.resultType: " & Me.resultType
 
  If IsEmpty(initialItemsArray) Then
      
    Select Case Me.resultType
    
      Case "Workbook"
        Me.itemsArray = GetWorkbooks()
  '      Debug.Print "InitializeForm > Me.itemsArray 0 & 1: "; Me.itemsArray(0).Name; ", "; Windows(Me.itemsArray(0).Name).Visible; ". "; Me.itemsArray(1).Name; ", "; Windows(Me.itemsArray(1).Name).Visible
      Case "Worksheet"
        Set sheetsCollection = GetSheets()
        Me.itemsArray = sheetsCollection("SheetsArray")
      '  Set parentWorkbook = sheetsCollection("ParentWorkbook")      'Not relevant when pass nothing to GetSheets?
      Case "Column"
        Set columnsCollection = GetColumns()
        Me.itemsArray = columnsCollection("ColumnsArray")
      '  Set parentWorksheet = sheetsCollection("ParentWorksheet")      'Not relevant when pass nothing to GetColumnss?
        
    End Select

  Else
    Me.itemsArray = initialItemsArray
  End If
  
      
  Select Case Me.resultType
  
    Case "Workbook"
      Call ListWorkbooks  '>>
      Call DisplayInputFields '>>
      
    Case "Worksheet"
      Call ListSheets  '>>
      Call DisplayInputFields '>>
      
    Case "Column"
      Call ListColumns  '>>
      Call DisplayInputFields '>>
      
    Case "Cell"
      Call DisplayInputFields '>>
    
    Case "ID"
      Call DisplayInputFields '>>
      
  End Select
  
  
